@page "/counter"
@rendermode InteractiveServer

<h1 class="page-title">Counter</h1>

<p class="page-subtitle">Simple interactive example.</p>

<div class="counter-card">
    <p>Current count: <strong>@currentCount</strong></p>

    <span @onclick="IncrementCount" style="display:inline-block;">
        <nimble-button appearance="primary">
            Click me
        </nimble-button>
    </span>
</div>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }
}