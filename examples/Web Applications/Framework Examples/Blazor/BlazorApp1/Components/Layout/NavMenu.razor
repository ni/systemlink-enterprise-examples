@inject NavigationManager Nav

<div class="nimble-nav">
    <div class="nav-links">
        <nimble-anchor class="@LinkClass("")" href="/">Home</nimble-anchor>
        <nimble-anchor class="@LinkClass("counter")" href="/counter">Counter</nimble-anchor>
        <nimble-anchor class="@LinkClass("weather")" href="/weather">Weather</nimble-anchor>
        <nimble-anchor class="@LinkClass("API")" href="/API">API</nimble-anchor>
    </div>
</div>

@code {
    private string RelativePath =>
        Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/');

    private string LinkClass(string path)
    {
        var current = RelativePath;

        // Home case
        if (string.IsNullOrEmpty(path))
            return string.IsNullOrEmpty(current) ? "nav-link active" : "nav-link";

        return current.StartsWith(path, StringComparison.OrdinalIgnoreCase)
            ? "nav-link active"
            : "nav-link";
    }
}